# ===== משתני סביבה לשרת =====
# העתק/י ל-.env ועדכן/י. אין להעלות את .env ל-git.

# שרת
PORT=4000
CLIENT_URL=http://localhost:5173

# בסיס נתונים (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clinic

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# העלאות
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
