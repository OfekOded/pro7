{
  "name": "clinic-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "מרפאה חכמה — שרת Node/Express (REST API, MVC) למערכת ניהול מרפאה",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
