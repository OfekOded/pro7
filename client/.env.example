# ===== משתני סביבה ללקוח (Vite) =====
# העתק/י קובץ זה ל-.env.local ועדכן/י ערכים. רק משתנים בקידומת VITE_
# נחשפים לקוד הלקוח.

# כתובת בסיס ל-REST API של השרת
VITE_API_URL=http://localhost:4000/api

# מצב תקשורת: "mock" (ברירת מחדל — שרת דמו בדפדפן, services/mockServer.js)
# או "server" (fetch אמיתי אל VITE_API_URL). מחליפים כשה-backend ממומש.
VITE_API_MODE=mock
